{
  "extends": [
    "@repo/typescript-config/svelte.json",
    "./.svelte-kit/tsconfig.json"
  ],
  "compilerOptions": {
    "strictNullChecks": true,
    "baseUrl": ".",
    "paths": {
      "$shared": ["src/shared"],
      "$shared/*": ["src/shared/*"],
      "$modules": ["src/modules"],
      "$modules/*": ["src/modules/*"],
      "$infrastructures": ["src/infrastructures"],
      "$infrastructures/*": ["src/infrastructures/*"]
    }
  }
}
