{
  "extends": "@monesto/typescript-config/svelte.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "*": ["../../node_modules/*"]
    },
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2021",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "incremental": true,
    "noEmit": false,
    "verbatimModuleSyntax": false,
    "isolatedModules": false,
    "lib": ["ES2021"],
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
